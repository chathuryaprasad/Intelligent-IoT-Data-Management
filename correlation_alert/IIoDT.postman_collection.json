	"item": [
		{
			"name": "Detect Correlation Alert",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var template = `",
							"<canvas id=\"myHeatmap\" height=\"75\"></canvas>",
							"",
							"<script src=\"https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.5.0/Chart.min.js\"></script>",
							"<script src=\"https://cdn.jsdelivr.net/npm/chartjs-plugin-heatmap\"></script>",
							"",
							"<script>",
							"    var ctx = document.getElementById(\"myHeatmap\");",
							"",
							"    var myHeatmap = new Chart(ctx, {",
							"        type: \"heatmap\",",
							"        data: {",
							"            datasets: [{",
							"                label: \"Correlation Heatmap\",",
							"                data: [],",
							"                backgroundColor: 'rgba(255, 99, 132, 0.5)',",
							"                borderColor: 'rgba(255, 99, 132, 1)',",
							"                borderWidth: 1",
							"            }]",
							"        },",
							"        options: {",
							"            scales: {",
							"                xAxes: [{",
							"                    type: 'category',",
							"                    labels: ['s1', 's2', 's3'],",
							"                    scaleLabel: {",
							"                        display: true,",
							"                        labelString: 'Streams'",
							"                    }",
							"                }],",
							"                yAxes: [{",
							"                    type: 'category',",
							"                    labels: ['s1', 's2', 's3'],",
							"                    scaleLabel: {",
							"                        display: true,",
							"                        labelString: 'Streams'",
							"                    }",
							"                }]",
							"            }",
							"        }",
							"    });",
							"",
							"    pm.getData(function (err, value) {",
							"        var correlations = value.response.correlations;",
							"        var heatmapData = [];",
							"",
							"        correlations.forEach(cor => {",
							"            Object.keys(cor.correlation_matrix).forEach(key1 => {",
							"                Object.keys(cor.correlation_matrix[key1]).forEach(key2 => {",
							"                    heatmapData.push({",
							"                        x: key1,",
							"                        y: key2,",
							"                        v: cor.correlation_matrix[key1][key2]",
							"                    });",
							"                });",
							"            });",
							"        });",
							"",
							"        myHeatmap.data.datasets[0].data = heatmapData;",
							"        myHeatmap.update();",
							"    });",
							"</script>`;",
							"",
							"function constructVisualizerPayload() {",
							"    var res = pm.response.json();",
							"    ",
							"    return { response: res };",
							"}",
							"",
							"pm.visualizer.set(template, constructVisualizerPayload());"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
